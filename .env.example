APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=high_performance
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

MAX_CONCURRENT_CHECKOUTS=30
CAPACITY_SLOT_TTL=120
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_SECONDS=30
BATCH_CHUNK_SIZE=100

PAYMENT_SIMULATION_DELAY_MS=1500
USER_INITIAL_BALANCE=10000
PRODUCT_CACHE_TTL=300
STRESS_TEST_USERS=100
STRESS_TEST_BASE_URL=http://127.0.0.1:8000

JOB_INVOICE_TRIES=2
JOB_INVOICE_TIMEOUT=120
JOB_INVOICE_BACKOFF=10
JOB_INVOICE_FAIL_ON_TIMEOUT=true

JOB_NOTIFICATION_TRIES=2
JOB_NOTIFICATION_TIMEOUT=60
JOB_NOTIFICATION_BACKOFF=10
JOB_NOTIFICATION_FAIL_ON_TIMEOUT=true

JOB_BATCH_TRIES=2
JOB_BATCH_TIMEOUT=900
JOB_BATCH_BACKOFF=10
JOB_BATCH_FAIL_ON_TIMEOUT=true

CACHE_STORE=octane
# CACHE_PREFIX=

OCTANE_SERVER=swoole
OCTANE_HOST=127.0.0.1
OCTANE_PORT=8000
OCTANE_WORKERS=auto
OCTANE_TASK_WORKERS=auto
OCTANE_MAX_REQUESTS=500
OCTANE_GARBAGE=50
OCTANE_MAX_EXECUTION_TIME=30
OCTANE_CACHE_ROWS=10000
OCTANE_CACHE_BYTES=10000

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
